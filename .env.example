# 超级家长 AI — 环境配置

# 应用配置
APP_ENV=development
APP_DEBUG=true
APP_PORT=8000

# AI 模型 (可选 — 未配置时自动使用 Mock 模式)
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=https://api.openai.com/v1

# JWT 密钥 (生产环境请务必修改!)
JWT_SECRET=super-parent-jwt-secret-change-me

# 数据库路径 (默认: data/app.db)
DB_PATH=data/app.db

# CORS
CORS_ORIGINS=*
